---
import Layout from '../layouts/Layout.astro';
const baseRaw = import.meta.env.BASE_URL;
const base = baseRaw.endsWith('/') ? baseRaw : baseRaw + '/';
---

<Layout title="Meespelen" description="Wil je meespelen bij Bigband Survival? Ontdek hoe je kunt meedoen aan ons projectorkest.">
  
  <!-- Hero -->
  <section class="hero py-20">
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6" style="font-family: 'Playfair Display', serif;">
        Meespelen
      </h1>
      <p class="text-xl text-white/80 max-w-2xl">
        Sluit je aan bij Bigband Survival en ervaar hoe het is om onderdeel te zijn 
        van een echte bigband.
      </p>
    </div>
  </section>

  <!-- How it Works -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-3xl font-bold mb-12 text-center">Hoe werkt het?</h2>
      
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 rounded-full bg-brass text-white flex items-center justify-center text-2xl font-bold mx-auto mb-4">1</div>
          <h3 class="text-xl font-bold mb-3">Aanmelden</h3>
          <p class="text-gray-600">
            Neem contact met ons op via het formulier of mail. Vertel welk instrument 
            je speelt en hoelang je al les hebt.
          </p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 rounded-full bg-coral text-white flex items-center justify-center text-2xl font-bold mx-auto mb-4">2</div>
          <h3 class="text-xl font-bold mb-3">Kennismaken</h3>
          <p class="text-gray-600">
            We nodigen je uit voor een proefrepetitie. Geen stress — 
            we kijken gewoon of het klikt en je je op je gemak voelt.
          </p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 rounded-full bg-midnight text-white flex items-center justify-center text-2xl font-bold mx-auto mb-4">3</div>
          <h3 class="text-xl font-bold mb-3">Meespelen!</h3>
          <p class="text-gray-600">
            Bevalt het? Dan sluit je je aan bij het volgende project. 
            Je krijgt bladmuziek en we gaan aan de slag.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Requirements -->
  <section class="section-cream py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <h2 class="text-3xl font-bold mb-6">Wat vragen wij?</h2>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <span class="text-brass text-xl mt-1">✓</span>
              <div>
                <strong>Basisvaardigheid op je instrument</strong>
                <p class="text-gray-600">Minimaal 1-2 jaar les. Je hoeft geen virtuoos te zijn, maar de basis moet er zijn.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-brass text-xl mt-1">✓</span>
              <div>
                <strong>Noten kunnen lezen</strong>
                <p class="text-gray-600">We spelen van bladmuziek, dus enige notenleesvaardigheid is nodig.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-brass text-xl mt-1">✓</span>
              <div>
                <strong>Commitment voor het project</strong>
                <p class="text-gray-600">6-8 weken, elke zaterdag. Plus het afsluitende concert.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-brass text-xl mt-1">✓</span>
              <div>
                <strong>Enthousiasme!</strong>
                <p class="text-gray-600">De rest leer je vanzelf. Fouten maken mag — daar leer je van.</p>
              </div>
            </li>
          </ul>
        </div>
        
        <div>
          <h2 class="text-3xl font-bold mb-6">Welke instrumenten?</h2>
          <div class="space-y-4">
            <div class="bg-white rounded-xl p-4 card">
              <h3 class="font-bold mb-2">🎺 Koper</h3>
              <p class="text-gray-600">Trompet, Trombone, Hoorn, Tuba</p>
            </div>
            <div class="bg-white rounded-xl p-4 card">
              <h3 class="font-bold mb-2">🎷 Hout</h3>
              <p class="text-gray-600">Alt-, Tenor-, Baritonsax, Klarinet, Fluit</p>
            </div>
            <div class="bg-white rounded-xl p-4 card">
              <h3 class="font-bold mb-2">🎹 Ritme</h3>
              <p class="text-gray-600">Piano/Keyboard, Gitaar, Basgitaar, Drums</p>
            </div>
            <div class="bg-white rounded-xl p-4 card">
              <h3 class="font-bold mb-2">🎤 Zang</h3>
              <p class="text-gray-600">Voor sommige projecten zoeken we ook zangers</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Repertoire -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-3xl font-bold mb-6 text-center">Wat spelen we?</h2>
      <p class="text-center text-lg text-gray-600 max-w-2xl mx-auto mb-12">
        Onze repertoirekeuze is breed. We geloven dat een goede muzikant veel stijlen kan spelen.
      </p>
      
      <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-6">
        <div class="bg-midnight text-white rounded-xl p-6 text-center">
          <h3 class="text-xl font-bold mb-2">Swing</h3>
          <p class="text-white/70 text-sm">De klassieker. Count Basie, Duke Ellington.</p>
        </div>
        <div class="bg-coral text-white rounded-xl p-6 text-center">
          <h3 class="text-xl font-bold mb-2">Funk</h3>
          <p class="text-white/70 text-sm">Tower of Power, Earth Wind & Fire.</p>
        </div>
        <div class="bg-brass text-white rounded-xl p-6 text-center">
          <h3 class="text-xl font-bold mb-2">Latin</h3>
          <p class="text-white/70 text-sm">Salsa, Bossa nova, Afro-Cuban.</p>
        </div>
        <div class="bg-navy text-white rounded-xl p-6 text-center">
          <h3 class="text-xl font-bold mb-2">Pop</h3>
          <p class="text-white/70 text-sm">Moderne hits in bigband-jasje.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Costs -->
  <section class="section-cream py-20">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold mb-6">Kosten</h2>
      <p class="text-lg text-gray-600 mb-8">
        We vragen een kleine bijdrage per project om materialen en zaalhuur te dekken.
      </p>
      <div class="bg-white rounded-2xl p-8 card inline-block">
        <p class="text-5xl font-bold text-brass mb-2">€75</p>
        <p class="text-gray-600">per project (6-8 weken)</p>
        <p class="text-sm text-gray-500 mt-4">Inclusief bladmuziek en toegang tot alle repetities</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-dark py-16">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold mb-4">Overtuigd?</h2>
      <p class="text-white/80 mb-6">Meld je aan voor het volgende project!</p>
      <a href={`${base}contact/`} class="btn-primary">Aanmelden →</a>
    </div>
  </section>

</Layout>
