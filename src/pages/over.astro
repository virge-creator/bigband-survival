---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Over Ons" description="Leer meer over Bigband Survival - het projectorkest voor jonge muzikanten in Midden-Limburg.">
  
  <!-- Hero -->
  <section class="hero py-20">
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6" style="font-family: 'Playfair Display', serif;">
        Over Bigband Survival
      </h1>
      <p class="text-xl text-white/80 max-w-2xl">
        Een projectorkest geboren uit passie voor muziek en de wens om jonge talenten 
        een podium te geven.
      </p>
    </div>
  </section>

  <!-- Mission -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold mb-6">Onze Missie</h2>
          <p class="text-lg text-gray-600 mb-4">
            Bigband Survival is ontstaan vanuit een simpele observatie: veel muziekschoolleerlingen 
            krijgen nooit de kans om in een band te spelen. Ze leren noten lezen, oefenen thuis, 
            maar missen de ervaring van samen muziek maken.
          </p>
          <p class="text-lg text-gray-600 mb-4">
            Wij willen dat veranderen. Bij ons ontdekken jonge muzikanten wat het betekent om 
            onderdeel te zijn van iets groters. Om te luisteren naar je mede-muzikanten. Om 
            risico's te nemen en te improviseren.
          </p>
          <p class="text-lg text-gray-600">
            En bovenal: om plezier te hebben in muziek.
          </p>
        </div>
        <div class="bg-cream rounded-2xl p-8">
          <h3 class="text-xl font-bold mb-4">Wat maakt ons uniek?</h3>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <span class="text-brass text-xl">🎯</span>
              <div>
                <strong>Focus op groei</strong>
                <p class="text-gray-600 text-sm">Niet perfectie, maar progressie staat centraal</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-brass text-xl">🌟</span>
              <div>
                <strong>Laagdrempelig</strong>
                <p class="text-gray-600 text-sm">Geen audities, wel een warm welkom</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-brass text-xl">🎭</span>
              <div>
                <strong>Echte optredens</strong>
                <p class="text-gray-600 text-sm">We spelen op lokale evenementen en festivals</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-brass text-xl">💡</span>
              <div>
                <strong>Improvisatie</strong>
                <p class="text-gray-600 text-sm">We stimuleren creativiteit en eigen inbreng</p>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- The Band -->
  <section class="section-cream py-20">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-3xl font-bold mb-12 text-center">De Bezetting</h2>
      <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-6">
        <div class="bg-white rounded-xl p-6 text-center card">
          <div class="text-4xl mb-3">🎺</div>
          <h3 class="font-bold mb-2">Trompetten</h3>
          <p class="text-gray-600 text-sm">4 posities</p>
        </div>
        <div class="bg-white rounded-xl p-6 text-center card">
          <div class="text-4xl mb-3">🎷</div>
          <h3 class="font-bold mb-2">Saxofoons</h3>
          <p class="text-gray-600 text-sm">Alto, Tenor, Bari</p>
        </div>
        <div class="bg-white rounded-xl p-6 text-center card">
          <div class="text-4xl mb-3">📯</div>
          <h3 class="font-bold mb-2">Trombones</h3>
          <p class="text-gray-600 text-sm">4 posities</p>
        </div>
        <div class="bg-white rounded-xl p-6 text-center card">
          <div class="text-4xl mb-3">🎹</div>
          <h3 class="font-bold mb-2">Ritme</h3>
          <p class="text-gray-600 text-sm">Piano, bas, drums, gitaar</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Location -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold mb-6">Waar repeteren we?</h2>
          <p class="text-lg text-gray-600 mb-4">
            Onze repetities vinden plaats in het hart van Midden-Limburg. 
            Goed bereikbaar voor muzikanten uit de hele regio.
          </p>
          <div class="bg-cream rounded-xl p-6 mt-6">
            <h3 class="font-bold mb-2">📍 Locatie</h3>
            <p class="text-gray-600">
              Julianastraat 63<br>
              Stramproy
            </p>
          </div>
        </div>
        <div class="bg-navy rounded-2xl p-8 text-white">
          <h3 class="text-xl font-bold mb-4">Repetitie Schema</h3>
          <p class="text-white/80 mb-6">
            We repeteren in projectvorm: intensieve periodes van 6-8 weken, 
            eindigend met een optreden.
          </p>
          <ul class="space-y-3">
            <li class="flex items-center gap-3">
              <span class="text-brass">📅</span>
              <span>Zaterdagochtend 10:00 - 12:30</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="text-brass">🔄</span>
              <span>3-4 projecten per jaar</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="text-brass">🎤</span>
              <span>Elk project eindigt met optreden</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-dark py-16">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold mb-4">Nieuwsgierig geworden?</h2>
      <p class="text-white/80 mb-6">Kom een keer langs bij een repetitie!</p>
      <a href={`${base}contact/`} class="btn-primary">Neem contact op</a>
    </div>
  </section>

</Layout>
