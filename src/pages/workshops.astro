---
import Layout from '../layouts/Layout.astro';
const baseRaw = import.meta.env.BASE_URL;
const base = baseRaw.endsWith('/') ? baseRaw : baseRaw + '/';
---

<Layout title="Workshops" description="Improvisatie workshops en masterclasses bij Bigband Survival. Leer improviseren in een ontspannen setting.">
  
  <!-- Hero -->
  <section class="hero py-20">
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6" style="font-family: 'Playfair Display', serif;">
        Workshops
      </h1>
      <p class="text-xl text-white/80 max-w-2xl">
        Naast het projectorkest organiseren we regelmatig workshops over improvisatie, 
        samenspel en muzikaliteit.
      </p>
    </div>
  </section>

  <!-- Impro Workshop -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <span class="text-brass font-medium tracking-wider uppercase text-sm">Populair</span>
          <h2 class="text-3xl font-bold mt-2 mb-6">Improvisatie Workshop</h2>
          <p class="text-lg text-gray-600 mb-4">
            Improviseren lijkt eng, maar het is eigenlijk heel natuurlijk. In deze workshop 
            leer je de basis van jazz-improvisatie op een toegankelijke manier.
          </p>
          <ul class="space-y-3 mb-6">
            <li class="flex items-center gap-3">
              <span class="text-brass">✓</span>
              <span>Pentatonische en bluesscalen</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="text-brass">✓</span>
              <span>Call & response oefeningen</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="text-brass">✓</span>
              <span>Spelen over akkoordenschema's</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="text-brass">✓</span>
              <span>Je eerste solo's in een veilige setting</span>
            </li>
          </ul>
          <div class="bg-cream rounded-xl p-4 inline-block">
            <p class="text-sm text-gray-600"><strong>Duur:</strong> 3 uur | <strong>Max:</strong> 12 deelnemers</p>
          </div>
        </div>
        <div class="bg-midnight text-white rounded-2xl p-8">
          <div class="text-6xl mb-4">🎤</div>
          <h3 class="text-2xl font-bold mb-4">Volgende workshop</h3>
          <p class="text-white/80 mb-6">
            Data worden aangekondigd via onze nieuwsbrief en social media. 
            Houd de blog in de gaten!
          </p>
          <a href={`${base}contact/`} class="btn-primary">Interesse? Mail ons</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Other Workshops -->
  <section class="section-cream py-20">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-3xl font-bold mb-12 text-center">Andere Workshops</h2>
      
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl p-6 card">
          <div class="text-3xl mb-4">👂</div>
          <h3 class="text-xl font-bold mb-3">Luisteren & Reageren</h3>
          <p class="text-gray-600 mb-4">
            Leer luisteren naar je mede-muzikanten en gepast reageren. 
            Essentieel voor elk bandlid.
          </p>
          <p class="text-sm text-brass font-medium">2 uur</p>
        </div>
        
        <div class="bg-white rounded-xl p-6 card">
          <div class="text-3xl mb-4">🎼</div>
          <h3 class="text-xl font-bold mb-3">Bladmuziek Bootcamp</h3>
          <p class="text-gray-600 mb-4">
            Sneller en accurater bladlezen. Tips en trucs om nieuwe 
            stukken efficiënter onder de knie te krijgen.
          </p>
          <p class="text-sm text-brass font-medium">2.5 uur</p>
        </div>
        
        <div class="bg-white rounded-xl p-6 card">
          <div class="text-3xl mb-4">🥁</div>
          <h3 class="text-xl font-bold mb-3">Ritme & Timing</h3>
          <p class="text-gray-600 mb-4">
            Swing feel, latin grooves, funk pocket. Leer de subtiliteiten 
            van verschillende ritmes.
          </p>
          <p class="text-sm text-brass font-medium">2 uur</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Masterclasses -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold mb-4">Masterclasses</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Regelmatig nodigen we professionele muzikanten uit voor masterclasses. 
          Een unieke kans om te leren van de profs!
        </p>
      </div>
      
      <div class="bg-cream rounded-2xl p-8 md:p-12">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div>
            <h3 class="text-2xl font-bold mb-4">Wat kun je verwachten?</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <span class="text-brass text-xl">🎯</span>
                <span>Persoonlijke feedback op je spel</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-brass text-xl">💡</span>
                <span>Inzichten van werkende muzikanten</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-brass text-xl">🎵</span>
                <span>Samen spelen met een prof</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-brass text-xl">❓</span>
                <span>Q&A over carrière en muziek</span>
              </li>
            </ul>
          </div>
          <div class="text-center">
            <p class="text-5xl mb-4">🌟</p>
            <p class="text-gray-600">
              Masterclasses worden aangekondigd via onze blog en nieuwsbrief. 
              Meestal 2-3 keer per jaar.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Schools -->
  <section class="section-dark py-20">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold mb-6">Voor Muziekscholen</h2>
      <p class="text-white/80 text-lg mb-8">
        Wij komen ook naar jullie toe! We verzorgen workshops op locatie voor 
        muziekscholen in Midden-Limburg. Een perfecte aanvulling op het reguliere lesprogramma.
      </p>
      <a href={`${base}contact/`} class="btn-primary">Vraag een offerte aan</a>
    </div>
  </section>

</Layout>
