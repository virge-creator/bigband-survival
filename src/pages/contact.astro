---
import Layout from '../layouts/Layout.astro';
const baseRaw = import.meta.env.BASE_URL;
const base = baseRaw.endsWith('/') ? baseRaw : baseRaw + '/';
---

<Layout title="Contact" description="Neem contact op met Bigband Survival. We horen graag van je!">
  
  <!-- Hero -->
  <section class="hero py-20">
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6" style="font-family: 'Playfair Display', serif;">
        Contact
      </h1>
      <p class="text-xl text-white/80 max-w-2xl">
        Vragen? Interesse in meespelen? We horen graag van je!
      </p>
    </div>
  </section>

  <!-- Contact Info -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-12">
        
        <!-- Contact Form -->
        <div>
          <h2 class="text-2xl font-bold mb-6">Stuur een bericht</h2>
          <form class="space-y-6" action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
            <div>
              <label for="name" class="block text-sm font-medium mb-2">Naam *</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-brass focus:ring-2 focus:ring-brass/20 outline-none transition-colors"
                placeholder="Je naam"
              >
            </div>
            
            <div>
              <label for="email" class="block text-sm font-medium mb-2">E-mail *</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-brass focus:ring-2 focus:ring-brass/20 outline-none transition-colors"
                placeholder="je@email.nl"
              >
            </div>
            
            <div>
              <label for="instrument" class="block text-sm font-medium mb-2">Instrument</label>
              <select 
                id="instrument" 
                name="instrument"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-brass focus:ring-2 focus:ring-brass/20 outline-none transition-colors"
              >
                <option value="">Selecteer (optioneel)</option>
                <option value="trompet">Trompet</option>
                <option value="trombone">Trombone</option>
                <option value="altsax">Altsaxofoon</option>
                <option value="tenorsax">Tenorsaxofoon</option>
                <option value="barisax">Baritonsaxofoon</option>
                <option value="klarinet">Klarinet</option>
                <option value="fluit">Fluit</option>
                <option value="piano">Piano/Keyboard</option>
                <option value="gitaar">Gitaar</option>
                <option value="bas">Basgitaar</option>
                <option value="drums">Drums</option>
                <option value="zang">Zang</option>
                <option value="anders">Anders</option>
              </select>
            </div>
            
            <div>
              <label for="subject" class="block text-sm font-medium mb-2">Onderwerp *</label>
              <select 
                id="subject" 
                name="subject"
                required
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-brass focus:ring-2 focus:ring-brass/20 outline-none transition-colors"
              >
                <option value="">Selecteer een onderwerp</option>
                <option value="meespelen">Ik wil meespelen</option>
                <option value="workshop">Vraag over workshops</option>
                <option value="muziekschool">Samenwerking muziekschool</option>
                <option value="algemeen">Algemene vraag</option>
              </select>
            </div>
            
            <div>
              <label for="message" class="block text-sm font-medium mb-2">Bericht *</label>
              <textarea 
                id="message" 
                name="message" 
                rows="5"
                required
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-brass focus:ring-2 focus:ring-brass/20 outline-none transition-colors resize-none"
                placeholder="Vertel ons wat je wilt weten..."
              ></textarea>
            </div>
            
            <button type="submit" class="btn-primary w-full">
              Verstuur bericht →
            </button>
          </form>
        </div>
        
        <!-- Contact Details -->
        <div>
          <h2 class="text-2xl font-bold mb-6">Contactgegevens</h2>
          
          <div class="space-y-6">
            <div class="bg-cream rounded-xl p-6">
              <h3 class="font-bold mb-2 flex items-center gap-2">
                <span class="text-xl">📧</span> E-mail
              </h3>
              <a href="mailto:info@bigbandsurvival.nl" class="text-brass hover:underline">
                info@bigbandsurvival.nl
              </a>
            </div>
            
            <div class="bg-cream rounded-xl p-6">
              <h3 class="font-bold mb-2 flex items-center gap-2">
                <span class="text-xl">📍</span> Locatie
              </h3>
              <p class="text-gray-600">
                Julianastraat 63<br>
                Stramproy
              </p>
            </div>
            
            <div class="bg-cream rounded-xl p-6">
              <h3 class="font-bold mb-2 flex items-center gap-2">
                <span class="text-xl">⏰</span> Repetities
              </h3>
              <p class="text-gray-600">
                Zaterdagochtend 10:00 - 12:30<br>
                <span class="text-sm">(tijdens projectperiodes)</span>
              </p>
            </div>
          </div>
          
          <div class="mt-8 p-6 bg-midnight text-white rounded-xl">
            <h3 class="font-bold mb-3">💡 Tip</h3>
            <p class="text-white/80 text-sm">
              Wil je meespelen? Vermeld in je bericht welk instrument je speelt 
              en hoelang je al les hebt. Dan kunnen we je sneller helpen!
            </p>
          </div>
        </div>
        
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-cream py-20">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-bold mb-12 text-center">Veelgestelde Vragen</h2>
      
      <div class="space-y-6">
        <div class="bg-white rounded-xl p-6 card">
          <h3 class="font-bold mb-2">Moet ik auditie doen?</h3>
          <p class="text-gray-600">
            Nee! We nodigen je uit voor een vrijblijvende proefrepetitie. 
            Geen stress, gewoon even kijken of het klikt.
          </p>
        </div>
        
        <div class="bg-white rounded-xl p-6 card">
          <h3 class="font-bold mb-2">Hoe goed moet ik zijn?</h3>
          <p class="text-gray-600">
            Je hoeft geen virtuoos te zijn. Als je minimaal 1-2 jaar les hebt 
            en noten kunt lezen, ben je welkom. De rest leer je bij ons.
          </p>
        </div>
        
        <div class="bg-white rounded-xl p-6 card">
          <h3 class="font-bold mb-2">Wat als ik een repetitie moet missen?</h3>
          <p class="text-gray-600">
            Dat kan gebeuren. We vragen wel commitment voor de meeste repetities, 
            vooral richting het eindconcert. Overleg even als je weet dat je er niet kunt zijn.
          </p>
        </div>
        
        <div class="bg-white rounded-xl p-6 card">
          <h3 class="font-bold mb-2">Ik speel geen bigband-instrument. Kan ik toch meedoen?</h3>
          <p class="text-gray-600">
            Laat het ons weten! Soms hebben we arrangementen die ruimte bieden 
            voor andere instrumenten. We kijken graag naar de mogelijkheden.
          </p>
        </div>
      </div>
    </div>
  </section>

</Layout>
